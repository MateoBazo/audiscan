# Supabase — reemplazar con tus valores reales
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Conexión directa a PostgreSQL (via Supabase connection string)
# Usar el string de "Direct connection" del panel de Supabase
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@db.tu-proyecto.supabase.co:5432/postgres

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Entorno
ENVIRONMENT=development
DEBUG=true

# CORS — en producción, reemplazar * por el dominio real
ALLOWED_ORIGINS=["*"]
